KEEPA_API_KEY=your_keepa_api_key_here
ASIN=B001E4KFG0
TELEGRAM_SEND_SCRIPT=/path/to/telegram-send.sh

# Human-readable product name shown in Telegram alerts (falls back to ASIN if unset)
PRODUCT_NAME=Ethiopian Yirgacheffe Coffee

# Alert threshold — choose one approach:
#
# Absolute: fire when current price (cents) drops below this value.
#   e.g. PRICE_THRESHOLD_CENTS=1999  → alert when price < $19.99
PRICE_THRESHOLD_CENTS=

# Relative (used when PRICE_THRESHOLD_CENTS is unset): fire when latest price
# has dropped ≥ this many percent below the previous observed price.
# Defaults to 10 if neither variable is set.
PRICE_DROP_PCT=10
