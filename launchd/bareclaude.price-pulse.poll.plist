<plist version="1.0">
<dict>
  <key>Label</key>
  <string>bareclaude.price-pulse.poll</string>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>/Users/daelegbe/BareClaude/finn/repos/price-pulse/dist/pipeline.js</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>DB_PATH</key>
    <string>/Users/daelegbe/BareClaude/finn/.state/price-pulse.db</string>
